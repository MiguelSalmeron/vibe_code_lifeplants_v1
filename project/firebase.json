{
  "hosting": {
    "site": "life--plants-app",
    "public": "build/client",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      { "source": "/ia.html", "destination": "/ia", "type": 301 },
      { "source": "/raiz.html", "destination": "/ia", "type": 301 }
    ],
    "rewrites": [
      { "source": "/api/chat", "function": "chat" },
      { "source": "/api/tts",  "function": "tts" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "raiz/functions",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
